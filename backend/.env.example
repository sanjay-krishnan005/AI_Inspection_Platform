# AI Inspect Pro - Production Environment Variables

# ========================================
# DATABASE (Supabase)
# ========================================
# Replace with your Supabase Transaction connection string (Session Mode)
# Example: postgresql://postgres.xxxxxx:password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
DATABASE_URL=""

# ========================================
# AWS S3 STORAGE (For Uploads)
# ========================================
# Your AWS IAM user keys with S3 bucket write permissions
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_BUCKET_NAME=""

# ========================================
# AI SERVICES (Groq API)
# ========================================
GROQ_API_KEY="your_groq_api_key_here"

# ========================================
# SECURITY (JWT & Admin Config)
# ========================================
# Generate a strong 32-character secret key for JWT token signing
SECRET_KEY="replace_with_a_very_strong_random_secret_string"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="10080"  # 7 days

# Default Admin User details for seed script
ADMIN_EMAIL="admin@aiinspect.pro"
ADMIN_PHONE="+1234567890"

# ========================================
# EMAIL CONFIG (Optional - SMTP)
# ========================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
